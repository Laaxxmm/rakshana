# --- Database -----------------------------------------------------------
POSTGRES_PASSWORD=rakshana_dev
DATABASE_URL="postgresql://rakshana:rakshana_dev@localhost:5432/rakshana?schema=public"

# --- Auth ---------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- App ---------------------------------------------------------------
NODE_ENV="development"

# --- Storage -----------------------------------------------------------
# "local" (default) writes to <repo>/.uploads. "r2" is a stub for Phase 6.
STORAGE_BACKEND="local"
# Override the local-FS root path. Defaults to <cwd>/.uploads.
# LOCAL_STORAGE_ROOT="/Users/me/rakshana-uploads"

# --- Notify ------------------------------------------------------------
# EMAIL_DRIVER options:
#   "console"  → dev default, logs to server stdout
#   "smtp"     → any SMTP (Gmail, Outlook, custom). Set SMTP_* vars below.
#   "resend"   → Resend transactional API (set RESEND_API_KEY).
EMAIL_DRIVER="console"

# --- Gmail SMTP (free, 500/day) -----------
# 1. Enable 2FA on the Gmail account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Use the 16-char password (no spaces) below
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="youraddress@gmail.com"
# SMTP_PASS="abcdefghijklmnop"
# EMAIL_FROM="Rakshana Trust <youraddress@gmail.com>"

# --- Resend (transactional, free 3k/month) -----------
# RESEND_API_KEY="re_…"
# EMAIL_FROM="Rakshana Trust <receipts@rakshana.org>"

# WHATSAPP_DRIVER options:
#   "console" → dev default, logs to server stdout
#   "link"    → builds wa.me click-to-chat URLs (free, manual tap-Send)
#   "cloud"   → Meta WhatsApp Cloud API (automated, business verification required)
WHATSAPP_DRIVER="console"
# No additional env vars for "link" — works out of the box.
# For "cloud":
# WHATSAPP_PHONE_ID="…"
# WHATSAPP_ACCESS_TOKEN="…"
