# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Local-FS storage backend (Phase 1 dev uploads)
/.uploads

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local-only planning / session docs — never commit these
CLAUDE.md
AGENTS.md
Phase-*-Prompt.md
PHASE-*-COMPLETE.md
PHASE-*-VALIDATION-LOG.md
Rakshana-PRD.md
