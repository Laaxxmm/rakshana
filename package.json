    "@tabler/icons-react": "^3.44.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "date-fns-tz": "^3.2.0",
    "decimal.js": "^10.6.0",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.16.0",
