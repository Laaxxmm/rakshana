// =====================================================================
// 13. PHASE 6 — REPORTS + JOB RUNS
// =====================================================================

/// Historical record of a generated report. The actual files live in storage;
/// this row stores the parameters + URLs for re-download.
model Report {
  id              String   @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  reportType      ReportType
  /// JSON snapshot of the parameters used to generate the report (FY, date range,
  /// project filter, etc.). Enables re-running the same report later.
  params          Json
  generatedAt     DateTime @default(now())
  generatedById   String?
  generatedBy     User?    @relation("ReportGeneratedBy", fields: [generatedById], references: [id])
  pdfStorageKey   String?
  pdfUrl          String?
  excelStorageKey String?
  excelUrl        String?
  status          ReportStatus @default(GENERATING)
  errorMessage    String?

  @@index([organisationId, reportType, generatedAt])
  @@index([organisationId, generatedAt])
}

enum ReportType {
  RECEIPT_PAYMENT
  INCOME_EXPENDITURE
  BALANCE_SHEET
  FUND_FLOW
  DONOR_WISE
  PROJECT_UTILISATION
  TDS_QUARTERLY
  GST_SUMMARY
  AUDIT_TRAIL
  BENEFICIARY_IMPACT
}

enum ReportStatus {
  GENERATING
  READY
  FAILED
}

/// Cron job health log. Phase 6 cron service writes one row per run.
model JobRun {
  id                String   @id @default(cuid())
  jobName           String
  startedAt         DateTime @default(now())
  finishedAt        DateTime?
  status            JobRunStatus @default(RUNNING)
  errorMessage      String?
  recordsProcessed  Int      @default(0)
  meta              Json?

  @@index([jobName, startedAt])
  @@index([status])
}

enum JobRunStatus {
  RUNNING
  SUCCESS
  FAILURE
}
