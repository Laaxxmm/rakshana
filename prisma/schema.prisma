// =====================================================================
// 6. INCOME TAX COMPLIANCE
// =====================================================================

model ItFiling {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  financialYear   String
  filingType      ItFilingType  // ITR7 / FORM_10 / FORM_10B / FORM_10BB
  dueDate         DateTime?
  preparedAt      DateTime?
  filedAt         DateTime?
  ackNumber       String?
  fileUrl         String?
  excelUrl        String?
  pdfUrl          String?
  status          ItFilingStatus @default(PENDING)
  taxLiability    Decimal @default(0) @db.Decimal(18, 2)
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organisationId, financialYear, filingType])
}

// Phase 5 — Form 10 accumulation tracker (Sec 11(2)).
model Accumulation {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  financialYear   String
  amount          Decimal @db.Decimal(18, 2)
  purpose         String  // free-text — e.g. "Construction of school building"
  periodYears     Int     @default(5)
  startDate       DateTime
  endDate         DateTime
  status          AccumulationStatus @default(ACTIVE)
  supportDocUrl   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organisationId, financialYear])
  @@index([organisationId, status])
}

// Yearly snapshot for 85% rule monitoring and ITR-7 figures
model FinancialYearSummary {
  id                       String @id @default(cuid())
  organisationId           String
  financialYear            String
  totalReceipts            Decimal @default(0) @db.Decimal(18, 2)
  corpusDonations          Decimal @default(0) @db.Decimal(18, 2)
  fcraDonations            Decimal @default(0) @db.Decimal(18, 2)
  anonymousDonations       Decimal @default(0) @db.Decimal(18, 2)
  totalApplication         Decimal @default(0) @db.Decimal(18, 2)
  revenueApplication       Decimal @default(0) @db.Decimal(18, 2)
  capitalApplication       Decimal @default(0) @db.Decimal(18, 2)
  accumulatedUnderSec11_2  Decimal @default(0) @db.Decimal(18, 2)
  applicationPercent       Decimal @default(0) @db.Decimal(5, 2)
  computedAt               DateTime @default(now())

  @@unique([organisationId, financialYear])
}

// =====================================================================
// 7. GST COMPLIANCE
// =====================================================================

model GstInvoiceSeries {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name            String
  prefix          String
  financialYear   String
  currentNumber   Int @default(0)
  width           Int @default(4)
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())

  @@unique([organisationId, name, financialYear])
}

// Phase 3 — voucher number allocator series.
// Separate from ReceiptSeries because vouchers have different audit treatment
// (general / petty cash / recurring run on independent counters).
model VoucherSeries {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  kind            VoucherSeriesKind
  name            String
  prefix          String
  separator       String @default("/")
  financialYear   String
  currentNumber   Int    @default(0)
  width           Int    @default(4)
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  expenses        Expense[]

  @@unique([organisationId, kind, financialYear])
}

// Phase 4 — certificate number allocator (utilisation + volunteer certs).
// Same share-core SQL as ReceiptSeries / VoucherSeries.
model CertificateSeries {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  kind            CertificateSeriesKind
  name            String
  prefix          String
  separator       String @default("/")
  financialYear   String
  currentNumber   Int    @default(0)
  width           Int    @default(4)
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  utilisationCerts UtilisationCertificate[]
  volunteerCerts   VolunteerCertificate[]
  form10BeCerts    Form10BECertificate[]

  @@unique([organisationId, kind, financialYear])
}

model GstInvoice {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  invoiceNumber   String
  invoiceDate     DateTime
  buyerName       String
  buyerGstin      String?
  buyerStateCode  String?
  placeOfSupply   String?
  isInterState    Boolean @default(false)
  isExempted      Boolean @default(false)
  exemptionRef    String?
  hsnSac          String?
  taxableValue    Decimal @db.Decimal(18, 2)
  cgst            Decimal @default(0) @db.Decimal(18, 2)
  sgst            Decimal @default(0) @db.Decimal(18, 2)
  igst            Decimal @default(0) @db.Decimal(18, 2)
  total           Decimal @db.Decimal(18, 2)
  status          GstInvoiceStatus @default(DRAFT)
  fileUrl         String?
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organisationId, invoiceNumber])
  @@index([organisationId, invoiceDate])
}

model GstFiling {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  filingType      GstFilingType   // GSTR1 / GSTR3B
  period          String          // "2025-04" (YYYY-MM)
  dueDate         DateTime
  preparedAt      DateTime?
  filedAt         DateTime?
  arnNumber       String?
  exportUrl       String?
  status          GstFilingStatus @default(PENDING)
  remarks         String?
  createdAt       DateTime @default(now())

  @@unique([organisationId, filingType, period])
}

// =====================================================================
// 8. TDS COMPLIANCE
// =====================================================================

model TdsEntry {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  expenseId       String?  @unique
  expense         Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  deducteeName    String
  deducteePan     String?
  section         String   // "194C", "194J", "192", "194I"
  amountPaid      Decimal  @db.Decimal(18, 2)
  tdsRate         Decimal  @db.Decimal(5, 2)
  tdsAmount       Decimal  @db.Decimal(18, 2)
  deductionDate   DateTime
  challanId       String?
  challan         TdsChallan? @relation(fields: [challanId], references: [id])
  quarter         String   // "Q1", "Q2", "Q3", "Q4"
  financialYear   String
  ldcCertificateId String?
  ldcCertificate  LdcCertificate? @relation(fields: [ldcCertificateId], references: [id])
  status          TdsEntryStatus @default(ACTIVE)
  remarks         String?
  createdAt       DateTime @default(now())

  @@index([organisationId, financialYear, quarter])
  @@index([organisationId, section])
  @@index([organisationId, status])
}

model TdsChallan {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  challanNumber   String
  bsrCode         String
  challanDate     DateTime
  amount          Decimal  @db.Decimal(18, 2)
  reconciledAmount Decimal @default(0) @db.Decimal(18, 2)
  section         String?
  fileUrl         String?
  remarks         String?
  createdAt       DateTime @default(now())

  entries         TdsEntry[]

  @@unique([organisationId, challanNumber])
}

model TdsReturn {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  formType        TdsReturnType  // FORM_26Q / FORM_24Q
  financialYear   String
  quarter         String
  dueDate         DateTime
  preparedAt      DateTime?
  filedAt         DateTime?
  ackNumber       String?
  fileUrl         String?
  status          TdsReturnStatus @default(PENDING)
  createdAt       DateTime @default(now())

  @@unique([organisationId, formType, financialYear, quarter])
}

model LdcCertificate {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  deducteeName    String
  deducteePan     String
  section         String
  certNumber      String
  lowerRate       Decimal  @db.Decimal(5, 2)
  validFrom       DateTime
  validTo         DateTime
  fileUrl         String?
  remarks         String?
  createdAt       DateTime @default(now())

  entries         TdsEntry[]

  @@index([organisationId, deducteePan])
}

// =====================================================================
// 12. COMPLIANCE CALENDAR & NOTIFICATIONS
// =====================================================================

model ComplianceItem {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  category        ComplianceCategory   // GST / TDS / IT / FCRA / INTERNAL
  title           String
  description     String?
  dueDate         DateTime
  responsibleUserId String?
  status          ComplianceStatus @default(UPCOMING)
  completedAt     DateTime?
  referenceUrl    String?
  referenceModel  String?  // e.g. "ItFiling", "GstFiling"
  referenceId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organisationId, dueDate])
  @@index([organisationId, status])
}

model Notification {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?   @relation(fields: [userId], references: [id])
  channel         NotificationChannel
  title           String
  body            String  @db.Text
  link            String?
  isRead          Boolean @default(false)
  readAt          DateTime?
  sentAt          DateTime?
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([organisationId, userId, isRead])
}

// =====================================================================
// AUDIT TRAIL
// =====================================================================

model AuditLog {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?   @relation(fields: [userId], references: [id])
  action          String  // "donation.create", "expense.approve", etc.
  entityType      String  // "Donation", "Expense", etc.
  entityId        String
  before          Json?
  after           Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([organisationId, entityType, entityId])
  @@index([organisationId, userId, createdAt])
  @@index([organisationId, createdAt])
}

