// =====================================================================
// Rakshana — Trust Management Platform
// Prisma Schema · v1 (Draft, pre-build)
//
// Conventions
// - Every domain table has organisationId (multi-tenant safe from day one)
// - Money is Decimal(18,2)
// - Dates are DateTime (UTC); UI formats to IST
// - Soft-delete via status flags or `deletedAt`; never hard delete financials
// - Audit trail via AuditLog (append-only)
// - cuid() for IDs (URL-safe, sortable enough, collision-resistant)
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// 0. TENANT & ACCESS
// =====================================================================

model Organisation {
  id                 String   @id @default(cuid())
  name               String
  legalName          String?
  charitablePurpose  String?
  subCategory        String?  // e.g. "Education", "Healthcare", "Rural Development"

  // Contact
  phone              String?
  email              String?
  website            String?

  // Registered address (denormalised — simple for MVP)
  addressLine1       String?
  addressLine2       String?
  city               String?
  district           String?
  state              String?   // Use state codes from a constant list
  stateCode          String?   // 2-digit GST state code
  pincode            String?
  country            String   @default("India")

  // Legal identity
  registrationType   RegistrationType @default(TRUST)
  registrationNumber String?
  registrationDate   DateTime?
  pan                String?
  tan                String?
  cin                String?  // For Section 8 companies

  // Authorised signatory
  authorisedSignatoryName        String?
  authorisedSignatoryDesignation String?

  // Tax & funding registrations
  twelveA            TwelveARegistration?
  eightyG            EightyGRegistration?
  gstRegistration    GstRegistration?
  fcra               FcraRegistration?
  darpan             DarpanRegistration?
  csrOne             CsrOneRegistration?

  // CA / Advisor
  caFirmName         String?
  caPartnerName      String?
  caEmail            String?
  caPhone            String?

  // Branding
  logoUrl            String?
  signatureImageUrl  String?
  receiptHeaderText  String?
  receiptFooterText  String?

  // Financial year
  fyStartMonth       Int      @default(4)  // April
  fyStartDay         Int      @default(1)

  // Expense controls (Phase 3)
  billRequiredThreshold Decimal @default(5000) @db.Decimal(18, 2)
  pettyCashThreshold    Decimal @default(2000) @db.Decimal(18, 2)

  // Beneficiary controls (Phase 4)
  disbursementAckThreshold Decimal @default(1000) @db.Decimal(18, 2)

  // Status & timestamps
  status             OrgStatus @default(ACTIVE)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  memberships        Membership[]
  bankAccounts       BankAccount[]
  documents          OrgDocument[]
  donors             Donor[]
  donations          Donation[]
  receiptSeries      ReceiptSeries[]
  expenses           Expense[]
  vendors            Vendor[]
  pettyCashFloats    PettyCashFloat[]
  recurringExpenses  RecurringExpense[]
  expenseCategories  ExpenseCategory[]
  approvalPolicies   ApprovalPolicy[]
  projects           Project[]
  beneficiaries      Beneficiary[]
  volunteers         Volunteer[]
  volunteerActivities VolunteerActivity[]
  form10bdFilings    Form10BDFiling[]
  itFilings          ItFiling[]
  gstInvoices        GstInvoice[]
  gstInvoiceSeries   GstInvoiceSeries[]
  voucherSeries      VoucherSeries[]
  certificateSeries  CertificateSeries[]
  accumulations      Accumulation[]
  reports            Report[]
  gstFilings         GstFiling[]
  tdsEntries         TdsEntry[]
  tdsChallans        TdsChallan[]
  tdsReturns         TdsReturn[]
  ldcCertificates    LdcCertificate[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  communications     Communication[]
  complianceItems    ComplianceItem[]

  @@index([status])
}

model TwelveARegistration {
  id               String   @id @default(cuid())
  organisationId   String   @unique
  organisation     Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  number           String
  registrationDate DateTime
  validityEndDate  DateTime?
  documentUrl      String?
  isProvisional    Boolean  @default(false)
  remarks          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model EightyGRegistration {
  id               String   @id @default(cuid())
  organisationId   String   @unique
  organisation     Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  number           String
  approvalDate     DateTime
  validityEndDate  DateTime?
  documentUrl      String?
  isProvisional    Boolean  @default(false)
  remarks          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GstRegistration {
  id               String   @id @default(cuid())
  organisationId   String   @unique
  organisation     Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  gstin            String
  registrationDate DateTime
  documentUrl      String?
  remarks          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model FcraRegistration {
  id               String   @id @default(cuid())
  organisationId   String   @unique
  organisation     Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  number           String
  registrationDate DateTime
  validityEndDate  DateTime?
  fcraBankName     String?
  fcraBankAccountNumber String?
  fcraBankBranch   String?
  fcraBankIfsc     String?
  documentUrl      String?
  remarks          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DarpanRegistration {
  id               String   @id @default(cuid())
  organisationId   String   @unique
  organisation     Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  darpanId         String
  registrationDate DateTime?
  documentUrl      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CsrOneRegistration {
  id               String   @id @default(cuid())
  organisationId   String   @unique
  organisation     Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  csrOneRef        String
  registrationDate DateTime?
  documentUrl      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model OrgDocument {
  id             String   @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  category       OrgDocumentCategory
  title          String
  fileUrl        String
  mimeType       String?
  fileSize       Int?
  issueDate      DateTime?
  expiryDate     DateTime?
  remarks        String?
  uploadedById   String?
  uploadedBy     User?    @relation(fields: [uploadedById], references: [id])

  // Soft delete (financial discipline — no hard deletes)
  deletedAt      DateTime?

  // Replacement chain: when a doc is replaced, the OLD row's `replacedById`
  // points to the new row. The new row is the head of the chain.
  replacedById   String?
  replacedBy     OrgDocument?  @relation("OrgDocReplacement", fields: [replacedById], references: [id])
  replaces       OrgDocument[] @relation("OrgDocReplacement")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organisationId, category])
  @@index([organisationId, deletedAt])
  @@index([expiryDate])
}

model BankAccount {
  id             String   @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  bankName       String
  branch         String?
  accountNumber  String
  accountHolder  String?
  ifsc           String?
  accountType    BankAccountType @default(SAVINGS)
  purpose        BankAccountPurpose @default(GENERAL) // GENERAL / FCRA_ONLY / CORPUS
  openingBalance Decimal  @default(0) @db.Decimal(18, 2)
  isPrimary      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  donations      Donation[]
  expenses       Expense[]

  @@unique([organisationId, accountNumber])
  @@index([organisationId, isActive])
}

// ----- Auth & Users -----

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  emailVerified    DateTime?
  passwordHash     String?
  phone            String?
  avatarUrl        String?
  status           UserStatus @default(ACTIVE)
  lastLoginAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  memberships      Membership[]
  sessions         Session[]
  accounts         Account[]
  auditLogs        AuditLog[]
  uploadedDocs     OrgDocument[]
  createdDonations Donation[] @relation("DonationCreatedBy")
  createdExpenses  Expense[]  @relation("ExpenseCreatedBy")
  approvedExpenses ExpenseApproval[] @relation("ExpenseApprover")
  ownedProjects    Project[]  @relation("ProjectManager")
  communications   Communication[]
  notifications    Notification[]
  pettyCashFloats  PettyCashFloat[] @relation("PettyCashCustodian")
  generatedReports Report[]   @relation("ReportGeneratedBy")
}

// NextAuth-compatible
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  role           OrgRole
  customRoleId   String?
  customRole     Role?    @relation(fields: [customRoleId], references: [id])
  isActive       Boolean  @default(true)
  joinedAt       DateTime @default(now())

  @@unique([userId, organisationId])
  @@index([organisationId, role])
}

// Reserved for Phase 2 custom roles. Built-in roles use OrgRole enum.
model Role {
  id             String   @id @default(cuid())
  organisationId String
  name           String
  description    String?
  permissions    RolePermission[]
  memberships    Membership[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organisationId, name])
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique // e.g. "donation.create", "expense.approve"
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// =====================================================================
// 1. DONOR MANAGEMENT
// =====================================================================

model Donor {
  id              String   @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  donorType       DonorType
  name            String
  pan             String?
  aadhaarLast4    String?   // last 4 digits only, full Aadhaar never stored
  isAnonymousBucket Boolean @default(false) // system "Anonymous Donations" donor

  // Contact
  phone           String?
  whatsapp        String?
  email           String?

  // Address (mandatory for Form 10BD)
  addressLine1    String?
  addressLine2    String?
  city            String?
  district        String?
  state           String?
  stateCode       String?
  pincode         String?
  country         String   @default("India")

  // Flags
  is80GEligible   Boolean  @default(true)
  isFcraEligible  Boolean  @default(false)
  isCsrDonor      Boolean  @default(false)
  csrCompanyCin   String?  // For corporate CSR donors
  whatsappOptIn   Boolean  @default(true) // donor consent for WhatsApp dispatch; explicit opt-in arrives in Phase 7

  // Tags
  tags            String[] @default([])
  internalNotes   String?  // ADMIN+ only

  // Stats (denormalised, kept in sync via service layer)
  totalDonatedLifetime Decimal @default(0) @db.Decimal(18, 2)
  lastDonationDate     DateTime?

  status          DonorStatus @default(ACTIVE)
  createdAt       DateTime @default(now())
  createdById     String?
  updatedAt       DateTime @updatedAt

  donations       Donation[]
  documents       DonorDocument[]
  communications  Communication[]
  form10BeIssued  Form10BECertificate[]

  @@unique([organisationId, pan], map: "donor_org_pan_unique")
  @@index([organisationId, donorType])
  @@index([organisationId, name])
  @@index([organisationId, isAnonymousBucket])
}

model DonorDocument {
  id        String @id @default(cuid())
  donorId   String
  donor     Donor  @relation(fields: [donorId], references: [id], onDelete: Cascade)
  category  DonorDocumentCategory
  title     String
  fileUrl   String
  createdAt DateTime @default(now())
}

model Communication {
  id             String @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  donorId        String?
  donor          Donor? @relation(fields: [donorId], references: [id])
  channel        CommunicationChannel
  direction      CommunicationDirection @default(OUTBOUND)
  subject        String?
  body           String? @db.Text
  attachmentUrl  String?
  occurredAt     DateTime @default(now())
  sentById       String?
  sentBy         User?  @relation(fields: [sentById], references: [id])
  externalRef    String?  // WhatsApp message id, etc.
  createdAt      DateTime @default(now())

  @@index([organisationId, donorId])
  @@index([organisationId, occurredAt])
}

// =====================================================================
// 2. DONATION RECORDING
// =====================================================================

model ReceiptSeries {
  id              String   @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name            String   // "General", "FCRA", "Corpus"
  prefix          String   // "RKS/"
  financialYear   String   // "2025-26"
  separator       String   @default("/")
  width           Int      @default(4)
  currentNumber   Int      @default(0)
  isFcraOnly      Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  donations       Donation[]

  @@unique([organisationId, name, financialYear])
}

model Donation {
  id                 String   @id @default(cuid())
  organisationId     String
  organisation       Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  donorId            String
  donor              Donor    @relation(fields: [donorId], references: [id])

  receiptNumber      String   // Generated from series
  receiptSeriesId    String?
  receiptSeries      ReceiptSeries? @relation(fields: [receiptSeriesId], references: [id])

  donationDate       DateTime
  amount             Decimal  @db.Decimal(18, 2)
  currency           String   @default("INR")

  mode               DonationMode
  bankAccountId      String?
  bankAccount        BankAccount? @relation(fields: [bankAccountId], references: [id])
  paymentRef         String?  // Cheque no / UTR / UPI ref / DD no
  paymentDate        DateTime?  // For cheque clearing
  paymentRealisedDate DateTime?

  // In-kind
  isInKind           Boolean  @default(false)
  inKindDescription  String?
  inKindValuationMethod InKindValuationMethod?

  purpose            DonationPurpose @default(GENERAL)
  projectId          String?
  project            Project? @relation(fields: [projectId], references: [id])

  is80GEligible      Boolean  @default(true)

  isCsr              Boolean  @default(false)
  csrCompanyCin      String?

  isFcra             Boolean  @default(false)

  // 80G receipt
  receiptUrl         String?
  receiptGeneratedAt DateTime?
  amountInWords      String?

  // 10BD tracking
  isReportedIn10BD   Boolean  @default(false)
  form10BdFilingId   String?
  form10BdFiling     Form10BDFiling? @relation(fields: [form10BdFilingId], references: [id])
  donationTypeFor10BD Form10BDDonationType?  // Corpus / Specific grant / Others
  identificationTypeFor10BD String?  // PAN / Aadhaar / Tax Identification etc.

  status             DonationStatus @default(RECEIVED)
  cancellationReason String?
  cancelledAt        DateTime?
  cancelledById      String?
  remarks            String?

  createdById        String?
  createdBy          User?    @relation("DonationCreatedBy", fields: [createdById], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([organisationId, receiptNumber])
  @@index([organisationId, donationDate])
  @@index([organisationId, donorId])
  @@index([organisationId, donorId, donationDate])
  @@index([organisationId, projectId])
  @@index([organisationId, status])
  @@index([organisationId, isFcra])
  @@index([organisationId, isCsr])
  @@index([organisationId, donationDate, status])
}

// =====================================================================
// 4. EXPENSE MANAGEMENT
// =====================================================================

model Vendor {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name            String
  pan             String?
  gstin           String?
  defaultTdsSection String? // "194C", "194J", "192", "194I", etc.
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  stateCode       String?
  pincode         String?
  phone           String?
  email           String?
  bankName        String?
  bankAccountNumber String?
  bankIfsc        String?
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  expenses        Expense[]

  @@index([organisationId, name])
}

model ExpenseCategory {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name            String
  parentId        String?
  parent          ExpenseCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        ExpenseCategory[] @relation("CategoryHierarchy")
  isActive        Boolean @default(true)

  // Phase 3 — category-level rules surfaced on the expense form
  requiresProject     Boolean @default(false)
  defaultItcEligible  Boolean @default(true)
  isCapital           Boolean @default(false)
  fcraRestricted      Boolean @default(false)

  expenses        Expense[]

  @@unique([organisationId, name])
}

model Expense {
  id                  String   @id @default(cuid())
  organisationId      String
  organisation        Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  voucherNumber       String
  voucherSeriesId     String?
  voucherSeries       VoucherSeries? @relation(fields: [voucherSeriesId], references: [id])
  expenseDate         DateTime

  vendorId            String?
  vendor              Vendor?  @relation(fields: [vendorId], references: [id])
  cashPayeeName       String?  // one-off cash payouts without a vendor master record

  categoryId          String?
  category            ExpenseCategory? @relation(fields: [categoryId], references: [id])

  projectId           String?
  project             Project? @relation(fields: [projectId], references: [id])
  budgetHeadId        String?
  budgetHead          ProjectBudgetHead? @relation(fields: [budgetHeadId], references: [id])

  grossAmount         Decimal  @db.Decimal(18, 2)
  tdsAmount           Decimal  @default(0) @db.Decimal(18, 2)
  tdsSection          String?
  tdsRate             Decimal? @db.Decimal(5, 2)
  netPayable          Decimal  @db.Decimal(18, 2)
  exceededBudgetAt    DateTime? // audit trail for budget overrides

  // GST
  gstApplicable       Boolean  @default(false)
  cgst                Decimal  @default(0) @db.Decimal(18, 2)
  sgst                Decimal  @default(0) @db.Decimal(18, 2)
  igst                Decimal  @default(0) @db.Decimal(18, 2)
  isItcEligible       Boolean  @default(false)

  mode                PaymentMode
  bankAccountId       String?
  bankAccount         BankAccount? @relation(fields: [bankAccountId], references: [id])
  paymentRef          String?
  paidAt              DateTime?

  billUrl             String?
  description         String?

  isPettyCash         Boolean  @default(false)
  pettyCashFloatId    String?
  pettyCashFloat      PettyCashFloat? @relation(fields: [pettyCashFloatId], references: [id])

  recurringTemplateId String?
  recurringTemplate   RecurringExpense? @relation(fields: [recurringTemplateId], references: [id])

  status              ExpenseStatus @default(DRAFT)
  approvals           ExpenseApproval[]
  tdsEntry            TdsEntry?

  createdById         String?
  createdBy           User?    @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([organisationId, voucherNumber])
  @@index([organisationId, expenseDate])
  @@index([organisationId, vendorId])
  @@index([organisationId, projectId])
  @@index([organisationId, status])
}

model ExpenseApproval {
  id          String @id @default(cuid())
  expenseId   String
  expense     Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  approverId  String
  approver    User   @relation("ExpenseApprover", fields: [approverId], references: [id])
  level       Int    @default(1)
  decision    ApprovalDecision
  notes       String?
  decidedAt   DateTime @default(now())

  @@index([approverId, decision])
}

model ApprovalPolicy {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  scope           ApprovalScope @default(EXPENSE)
  minAmount       Decimal @db.Decimal(18, 2)
  maxAmount       Decimal? @db.Decimal(18, 2)
  requiredRole    OrgRole
  level           Int @default(1)
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())

  @@index([organisationId, scope])
}

model PettyCashFloat {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name            String
  custodianId     String?
  custodian       User?  @relation("PettyCashCustodian", fields: [custodianId], references: [id])
  floatAmount     Decimal @db.Decimal(18, 2)
  currentBalance  Decimal @default(0) @db.Decimal(18, 2)
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  expenses        Expense[]
  topUps          PettyCashTopUp[]
}

model PettyCashTopUp {
  id          String @id @default(cuid())
  floatId     String
  float       PettyCashFloat @relation(fields: [floatId], references: [id], onDelete: Cascade)
  amount      Decimal @db.Decimal(18, 2)
  topUpDate   DateTime
  bankAccountId String?
  remarks     String?
  createdAt   DateTime @default(now())
}

model RecurringExpense {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name            String
  vendorId        String?
  categoryId      String?
  projectId       String?
  amount          Decimal @db.Decimal(18, 2)
  frequency       RecurringFrequency
  nextDueDate     DateTime
  endDate         DateTime?
  isActive        Boolean @default(true)
  lastGeneratedFor DateTime? // job idempotency — last nextDueDate the runner consumed
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  generatedExpenses Expense[]
}

// =====================================================================
// 9. PROJECT MANAGEMENT
// =====================================================================

model Project {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  code            String
  name            String
  description     String? @db.Text
  startDate       DateTime?
  endDate         DateTime?
  totalBudget     Decimal @default(0) @db.Decimal(18, 2)
  managerId       String?
  manager         User?   @relation("ProjectManager", fields: [managerId], references: [id])
  isCsr           Boolean @default(false)
  isFcra          Boolean @default(false) // auto-flag from tagged FCRA donations
  status          ProjectStatus @default(PLANNED)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budgetHeads     ProjectBudgetHead[]
  grants          GrantAllocation[]
  donations       Donation[]
  expenses        Expense[]
  beneficiaryEnrolments BeneficiaryEnrolment[]
  utilisationCertificates UtilisationCertificate[]

  @@unique([organisationId, code])
  @@index([organisationId, status])
}

model ProjectBudgetHead {
  id          String @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String  // "Training", "Materials", "Salaries"
  budgetedAmount Decimal @db.Decimal(18, 2)
  expenses    Expense[]
  createdAt   DateTime @default(now())

  @@unique([projectId, name])
}

model GrantAllocation {
  id          String @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  donorId     String?
  description String  // e.g. "CSR grant FY 25-26 from Infosys"
  amount      Decimal @db.Decimal(18, 2)
  receivedOn  DateTime?
  remarks     String?
  createdAt   DateTime @default(now())
}

model UtilisationCertificate {
  id          String @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  donorId     String?
  certificateNumber String?
  certificateSeriesId String?
  certificateSeries CertificateSeries? @relation(fields: [certificateSeriesId], references: [id])
  periodFrom  DateTime
  periodTo    DateTime
  amountReceived Decimal @db.Decimal(18, 2)
  amountUtilised Decimal @db.Decimal(18, 2)
  balance     Decimal @db.Decimal(18, 2)
  fileUrl     String?
  status      String @default("ACTIVE") // ACTIVE | CANCELLED — for Phase 6 project-cancellation flow
  generatedAt DateTime @default(now())
  generatedById String?

  @@index([projectId, donorId])
}

// =====================================================================
// 10. BENEFICIARY MANAGEMENT
// =====================================================================

model Beneficiary {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  code            String?
  name            String
  dob             DateTime?
  gender          Gender?
  category        String? // "student", "patient", etc.
  phone           String?
  email           String?
  addressLine1    String?
  city            String?
  state           String?
  pincode         String?
  photoUrl        String?
  idProofUrl      String?
  internalNotes   String?
  status          BeneficiaryStatus @default(ACTIVE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  enrolments      BeneficiaryEnrolment[]
  disbursements   BeneficiaryDisbursement[]
  impactRecords   ImpactRecord[]

  @@unique([organisationId, code])
  @@index([organisationId, name])
}

model BeneficiaryEnrolment {
  id            String @id @default(cuid())
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project @relation(fields: [projectId], references: [id])
  enrolledOn    DateTime
  exitedOn      DateTime?
  remarks       String?

  @@unique([beneficiaryId, projectId])
}

model BeneficiaryDisbursement {
  id             String @id @default(cuid())
  beneficiaryId  String
  beneficiary    Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  disbursementDate DateTime
  type           DisbursementType
  value          Decimal @db.Decimal(18, 2)
  description    String?
  expenseId      String?  // optional link to expense voucher
  ackUrl         String?  // signature / OTP / photo proof
  createdAt      DateTime @default(now())
}

model ImpactRecord {
  id             String @id @default(cuid())
  beneficiaryId  String
  beneficiary    Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  recordDate     DateTime
  metricName     String
  metricValue    String  // free-form to keep schema flexible across programmes
  notes          String?
  createdAt      DateTime @default(now())
}

// =====================================================================
// 11. VOLUNTEER MANAGEMENT
// =====================================================================

model Volunteer {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name            String
  phone           String?
  email           String?
  skills          String[] @default([])
  availability    String?
  joinedOn        DateTime?
  status          VolunteerStatus @default(ACTIVE)
  totalHours      Decimal @default(0) @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments     VolunteerAssignment[]
  certificates    VolunteerCertificate[]

  @@index([organisationId, name])
}

model VolunteerActivity {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  location        String?
  startsAt        DateTime
  endsAt          DateTime?
  requiredVolunteers Int  @default(1)
  createdAt       DateTime @default(now())

  assignments     VolunteerAssignment[]
}

model VolunteerAssignment {
  id            String @id @default(cuid())
  volunteerId   String
  volunteer     Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  activityId    String
  activity      VolunteerActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  checkInAt     DateTime?
  checkOutAt    DateTime?
  hours         Decimal? @db.Decimal(10, 2)
  remarks       String?

  @@unique([volunteerId, activityId])
}

model VolunteerCertificate {
  id            String @id @default(cuid())
  volunteerId   String
  volunteer     Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  certificateNumber String?
  certificateSeriesId String?
  certificateSeries CertificateSeries? @relation(fields: [certificateSeriesId], references: [id])
  periodFrom    DateTime
  periodTo      DateTime
  totalHours    Decimal @db.Decimal(10, 2)
  fileUrl       String?
  generatedAt   DateTime @default(now())
}

// =====================================================================
// 5. FORM 10BD & 10BE
// =====================================================================

model Form10BDFiling {
  id              String @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  financialYear   String   // "2024-25"
  preparedAt      DateTime @default(now())
  preparedById    String?

  // Filing outcome
  filingStatus    Form10BDStatus @default(DRAFT)
  filedAt         DateTime?
  arnNumber       String?
  acknowledgementUrl String?
  csvExportUrl    String?

  totalDonations  Decimal @default(0) @db.Decimal(18, 2)
  totalDonors     Int     @default(0)

  // Phase 5 — revision tracking + human-readable summary
  summaryPdfUrl     String?
  isRevision        Boolean @default(false)
  originalFilingArn String?

  donations       Donation[]
  certificates    Form10BECertificate[]

  @@unique([organisationId, financialYear])
}

model Form10BECertificate {
  id              String @id @default(cuid())
  organisationId  String
  filingId        String
  filing          Form10BDFiling @relation(fields: [filingId], references: [id], onDelete: Cascade)
  donorId         String
  donor           Donor   @relation(fields: [donorId], references: [id])
  certificateNumber String?
  certificateSeriesId String?
  certificateSeries CertificateSeries? @relation(fields: [certificateSeriesId], references: [id])
  aggregateAmount Decimal @db.Decimal(18, 2)
